# Better Word For - Backend Configuration
# Copy this file to .env and fill in your values

# ── Database (NeonDB PostgreSQL) ──
# Get your connection string from https://neon.tech
# IMPORTANT: Use postgresql+asyncpg:// prefix and ?ssl=require (NOT sslmode)
DATABASE_URL=postgresql+asyncpg://user:password@your-host.neon.tech/dbname?ssl=require

# ── AI Provider (OpenRouter) ──
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── Speech-to-Text (Groq Whisper) ──
# Free API for voice input on browsers that block Web Speech API (e.g. Brave)
# Get your API key from https://console.groq.com/keys
GROQ_API_KEY=gsk_your-key-here

# ── App Settings ──
DEBUG=false
FRONTEND_URL=http://localhost:5173
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_DAY=500